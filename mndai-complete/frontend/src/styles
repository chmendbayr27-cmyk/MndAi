.auth-container {
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 100vh;
  padding: 20px;
}

.auth-form {
  width: 100%;
  max-width: 400px;
  padding: 30px;
}

.auth-form h1 {
  margin-bottom: 20px;
}

.auth-form input {
  width: 100%;
  padding: 12px;
  margin-bottom: 15px;
}

.auth-form button {
  width: 100%;
  padding: 12px;
  cursor: pointer;
}

.loading {
  text-align: center;
  padding: 50px;
}
